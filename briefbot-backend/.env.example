# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Optional: for JWT auth (Bearer token) in API
SUPABASE_ANON_KEY=

# AI (OpenRouter)
OPENROUTER_API_KEY=
APP_URL=https://briefbot.app

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Server
PORT=3001
NODE_ENV=development

# Optional: comma-separated proxy URLs for scraping
PROXY_LIST=

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=30

# Facebook scraper (optional)
# Strategy A: Graph API token for search (recommended)
FB_ACCESS_TOKEN=
# Strategy B: JSON string of cookies for logged-in scraping
FB_COOKIES=
